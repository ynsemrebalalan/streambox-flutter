# Lokal build secret'lari (gitignore'da). build_local.ps1 bu dosyayi okur,
# --dart-define ile flutter build'e gecirir.
#
# RC key'leri Codemagic UI -> Application -> Environment variables'da:
#   REVENUECAT_IOS_KEY      (appl_... ile baslar)
#   REVENUECAT_ANDROID_KEY  (goog_... ile baslar)
#
# Bu dosyayi kopyalayip "secrets.local.properties" olarak kaydet, key'leri yaz.

REVENUECAT_ANDROID_KEY=goog_REPLACE_ME
REVENUECAT_IOS_KEY=appl_REPLACE_ME

# Opsiyonel — bunlar zaten BuildConfig defaultValue'da gomulu, override icin:
# GROQ_PROXY_URL=https://iptvaiplayer.com.tr/api/groq-proxy.php
# GROQ_PROXY_SECRET=...
